{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay Pool Desktop",
  "version": "../package.json",
  "identifier": "dev.relaypool.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Relay Pool Desktop",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4N0E1NDMxNTIwNjRCNkYKUldSdlN3WlNNVlI2dUc3K0RxdjhlcWUrMUduemVhbzM3d1pFZXN5NzFDWW9pZWdidWlYTEE4cmsK",
      "endpoints": [
        "https://github.com/hardyz0517/relay-pool-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
